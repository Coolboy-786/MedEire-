# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Use "mongo" as the host inside Docker Compose. Use localhost for host-only npm runs.
MONGO_URI=mongodb://mongo:27017/medeire

# JWT
JWT_SECRET=replace_with_a_strong_random_string
JWT_EXPIRES_IN=7d

# Client
CLIENT_URL=http://localhost:3000

# Google OAuth
# Leave as "placeholder" to disable Google sign-in cleanly in local demos.
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# AI triage
# Leave as "placeholder" to use the rule-based triage fallback.
ANTHROPIC_API_KEY=placeholder
